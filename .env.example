# Copy to `.env` and fill in. Do NOT commit `.env`.

# === Required ===
OPENAI_API_KEY=sk-replace-me
# or
# ANTHROPIC_API_KEY=sk-ant-replace-me

# === Recommended free services (all optional, mocks work if unset) ===
TAVILY_API_KEY=tvly-replace-me
GITHUB_TOKEN=ghp-replace-me

# Mailtrap sandbox (sign up at https://mailtrap.io)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=replace-me
MAILTRAP_PASS=replace-me

# === Observability (recommended) ===
LANGSMITH_API_KEY=ls__replace-me
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=hiregraph-assignment-2

# === Toggles ===
# Force every external service to use its mock implementation.
HIREGRAPH_USE_MOCKS=true
